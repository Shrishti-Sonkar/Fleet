PORT=5000

# Razorpay credentials (get these from Razorpay Dashboard)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Firebase Admin configuration
# If running locally, you can download a service account JSON file from Firebase Console -> Project Settings -> Service Accounts.
# Set the path to the JSON file below, or populate the project ID if using default credentials credentials.
FIREBASE_PROJECT_ID=your_firebase_project_id_here
# GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account.json
