# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here
# Web Push (FCM): Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
VITE_FIREBASE_VAPID_KEY=your_web_push_vapid_key_here

# Backend API base URL
# In development, leave empty — Vite's dev proxy handles forwarding /api/* to your backend.
# In production, set this to your deployed backend origin, e.g.:
#   VITE_API_BASE_URL=https://fleet-backend.onrender.com
# VITE_API_BASE_URL=
PORT=5000

# Firebase Admin configuration
# If running locally, you can download a service account JSON file from Firebase Console -> Project Settings -> Service Accounts.
# Set the path to the JSON file below, or populate the project ID if using default credentials credentials.
FIREBASE_PROJECT_ID=fleetmobilities-3ee31
# GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account.json

# Allowed CORS origins (comma-separated)
# In development, the Vite dev server at http://localhost:5173 is included by default.
# In production, add your deployed frontend domain(s), e.g.:
#   CORS_ORIGINS=https://fleetmobilities.vercel.app,https://fleet.vercel.app
CORS_ORIGINS=http://localhost:5173
